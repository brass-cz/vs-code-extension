{
  "name": "prepoly-vs-code-extension",
  "displayName": "prepoly VS Code extension",
  "description": "VS Code extension for prepoly development",
  "version": "0.1.0",
  "author": "cordx56 <cord@x56.cx>",
  "publisher": "cordx56",
  "repository": {
    "type": "git",
    "url": "https://github.com/prepoly/vs-code-extension"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:prepoly"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "prepoly",
        "aliases": [
          "prepoly"
        ],
        "extensions": [
          ".pp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "prepoly.restartServer",
        "title": "Restart Language Server",
        "category": "prepoly"
      }
    ],
    "configuration": {
      "title": "prepoly",
      "properties": {
        "prepoly.server.path": {
          "type": "string",
          "default": "",
          "description": "Command used to start the prepoly language server. Leave empty to use `ppm lsp` from PATH."
        },
        "prepoly.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Arguments passed to the server command when prepoly.server.path is set (e.g. [\"lsp\"] for ppm)."
        },
        "prepoly.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the prepoly language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "vsce package --no-dependencies",
    "fmt": "prettier -w src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  }
}
